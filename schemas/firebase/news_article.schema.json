{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "News Article",
  "description": "Schema for news article entries stored in Firebase Firestore",
  "type": "object",
  "required": ["title", "description", "url", "category", "channel", "published_at", "article_id"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Article title"
    },
    "description": {
      "type": "string",
      "description": "Article description"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Article URL"
    },
    "channel": {
      "type": "string",
      "description": "News source name"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication timestamp in ISO 8601 format"
    },
    "article_id": {
      "type": "string",
      "description": "Article ID derived from URL (used as document ID in Firestore)"
    },
    "image": {
      "type": "string",
      "format": "uri",
      "description": "Article image URL"
    },
    "channel_url": {
      "type": "string",
      "format": "uri",
      "description": "News source URL"
    },
    "read": {
      "type": "boolean",
      "default": false,
      "description": "Whether the item has been read"
    }
  }
}