{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YouTube Video",
  "description": "Schema for YouTube video entries stored in Firebase Firestore",
  "type": "object",
  "required": ["title", "description", "url", "category", "channel", "published_at", "video_id"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Video title"
    },
    "description": {
      "type": "string",
      "description": "Video description"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "YouTube video URL"
    },
    "category": {
      "type": "string",
      "enum": ["video", "short"],
      "description": "Video category based on duration (< 4 min = short, >= 4 min = video)"
    },
    "channel": {
      "type": "string",
      "description": "Channel name"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication timestamp in ISO 8601 format"
    },
    "video_id": {
      "type": "string",
      "description": "YouTube video ID (used as document ID in Firestore)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Video tags"
    },
    "image": {
      "type": "string",
      "format": "uri",
      "description": "Video thumbnail URL"
    },
    "channel_url": {
      "type": "string",
      "format": "uri",
      "description": "Channel URL"
    },
    "read": {
      "type": "boolean",
      "default": false,
      "description": "Whether the item has been read"
    }
  }
}