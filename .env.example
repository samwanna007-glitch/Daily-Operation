# Google YouTube API
YOUTUBE_API_KEY=your_api_key_here
YOUTUBE_CHANNEL_IDS=channel_id_1,channel_id_2

# Notion
NOTION_API_KEY=your_notion_integration_key
NOTION_DATABASE_ID=your_youtube_database_id
NOTION_NEWS_DATABASE_ID=your_news_database_id

# GNews API
NEWS_API_KEY=your_gnews_api_key
NEWS_TOPICS=technology,science
NEWS_KEYWORDS=gemini,chatgpt,claude  # Optional: comma-separated keywords (takes precedence over topics)
NEWS_EXCLUDE=crypto,stocks  # Optional: comma-separated terms to exclude from search results

# Firebase (Optional - for Firebase database support)
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Optional
LOG_LEVEL=INFO
