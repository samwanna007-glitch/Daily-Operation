# ===========================================
# REQUIRED - Must be set for workflow to run
# ===========================================

# YouTube API Configuration
YOUTUBE_API_KEY=                    # REQUIRED: Google YouTube Data API v3 key

# At least ONE of these sources must be set (comma-separated values):
YOUTUBE_CHANNEL_IDS=                # YouTube channel IDs to fetch videos from
YOUTUBE_QUERIES=                   # Search queries to search for videos
YOUTUBE_VIDEO_IDS=                  # Specific video IDs to fetch directly

YOUTUBE_LIMIT=10                    # Optional: Max results per query (default: 10)
YOUTUBE_FROM_DATE=1                   # Optional: Days to look back for videos (default: 1)

# Notion API Configuration
NOTION_API_KEY=                     # REQUIRED: Notion integration token
NOTION_YOUTUBE_DATABASE_ID=          # REQUIRED: Notion database ID for storing video data

# ===========================================
# GNews API Configuration (News Tracker)
# ===========================================

# At least ONE news source must be set (comma-separated values):
GNEWS_TOPICS=                       # News topics to fetch (e.g., "technology,science")

# GNEWS_KEYWORDS is optional if GNEWS_TOPICS is set
GNEWS_KEYWORDS=                     # Optional: Search keywords for specific news topics

# Optional: Site-specific news sources
GNEWS_SITES=                        # Optional: News websites to fetch (e.g., "reuters.com,cnn.com")

# Optional: Location-based news
GNEWS_LOCATIONS=                    # Optional: Locations for local news (e.g., "New York City,Los Angeles")

GNEWS_LIMIT=10                      # Optional: Max results per category (default: 10)
GNEWS_FROM_DATE=1                    # Optional: News from X days ago (default: 1, meaning 1 day ago)

# Notion API Configuration for News
NOTION_NEWS_DATABASE_ID=             # REQUIRED: Notion database ID for storing news articles